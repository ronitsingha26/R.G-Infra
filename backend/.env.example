# ─── Environment ───────────────────────────────────────────────────────────
# Set this to "production" on Hostinger's environment panel
NODE_ENV=production

# ─── Server ────────────────────────────────────────────────────────────────
# Hostinger will inject PORT automatically — leave this for local dev
PORT=5001

# IMPORTANT: Use a long random string (min 32 chars). Never commit the real value.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_STRING_AT_LEAST_32_CHARACTERS

# ─── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list of frontend origins allowed to call your API.
# Use your actual Hostinger domain (no trailing slash).
ALLOWED_ORIGINS=https://prakashamgroup.com,https://www.prakashamgroup.com

# ─── MySQL ─────────────────────────────────────────────────────────────────
# Use the credentials from Hostinger → Databases → MySQL Databases
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_hostinger_db_user
DB_PASS=your_hostinger_db_password
DB_NAME=your_hostinger_db_name

# Set to "true" only if your Hostinger plan uses a remote MySQL host with SSL
DB_SSL=false

# ─── Email (Gmail SMTP — use an App Password, not your real password) ───────
# Guide: https://support.google.com/accounts/answer/185833
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx
EMAIL_FROM="Bajaj Developer Construction <your-gmail@gmail.com>"
